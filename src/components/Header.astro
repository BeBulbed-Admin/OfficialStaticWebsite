---
// src/components/Header.astro
const { isHome, isStatic } = Astro.props;
---
<nav class={isHome ? "home-nav" : (isStatic ? "static-nav" : "sticky-nav subpage-nav")}>
    <div class="nav-inner">
        { !isHome && (
            <a 
                href="/" 
                class={isStatic ? "nav-logo-center font-baumans" : "nav-logo-link font-baumans"} 
                style="text-decoration: none; color: var(--text-primary);"
            >
                <span class="flip-b">B</span><span class="logo-spacer"></span><span>B</span>
            </a>
        )}
    </div>
</nav>

<style>
    /* Theme logic for the Header */
    .nav-inner {
        transition: var(--theme-transition);
    }
    
    /* Ensure the B's respect the theme variable directly */
    .nav-logo-center, .nav-logo-link {
        color: var(--text-primary);
        transition: var(--theme-transition);
    }
</style>