---
// src/components/Footer.astro
---
<footer class="footer-system">
    <div class="footer-inner">
        <div class="footer-directory">
            <details class="apple-accordion">
                <summary class="apple-summary">
                    About Us
                    <svg class="apple-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="m6 9 6 6 6-6"/>
                    </svg>
                </summary>
                <div class="apple-accordion-content">
                    <a href="/newsroom" class="footer-link">Newsroom</a>
                    <a href="/contact" class="footer-link">Contact Us</a>
                </div>
            </details>
        </div>
        <div class="footer-bottom">
            <div class="footer-left">
                <span class="footer-text">
                    Copyright © 2026 <span class="font-baumans"><span class="flip-b">B</span>eBulbed</span>. All rights reserved.
                </span>
            </div>
            <div class="footer-right">
                <a href="/privacy" class="footer-link">Privacy Policy</a>
                <span class="footer-divider">|</span>
                <a href="/terms" class="footer-link">Terms of Use</a>
            </div>
        </div>
    </div>
</footer>

<style>
    /* Laboratory Theme Integration */
    .footer-system {
        transition: var(--theme-transition);
    }

    .footer-text, .footer-link {
        transition: var(--theme-transition);
    }

    .footer-text .font-baumans {
        font-size: 1.1em;
        color: inherit; 
        font-weight: 300;
        display: inline-block;
    }

    .flip-b {
        display: inline-block;
        transform: scaleX(-1);
    }

    /* Chevron respects the zinc-text variable automatically via stroke="currentColor" */
    .apple-chevron {
        color: var(--text-secondary);
        transition: transform 0.4s ease, color var(--theme-speed) ease;
    }
</style>