---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="BeBulbed" isHome={true}>
    <div class="top-fade-mask"></div>

    <header class="logo-hero-container" id="hero-container">
        <h1 class="hero-logo font-baumans">
            <span class="flip-b">B</span><span class="collapse-text">e</span><span class="logo-spacer"></span><span>B</span><span class="collapse-text">ulbed</span>
        </h1>
    </header>

    {/* The Referee: Forces the browser to finish scroll math before showing the logo */}
    <script is:inline>
        document.addEventListener("DOMContentLoaded", () => {
            // Double requestAnimationFrame ensures the browser has painted the initial frame 
            // and restored the scroll position before we trigger the fade-in.
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    const hero = document.getElementById("hero-container");
                    if (hero) hero.classList.add("is-ready");
                });
            });
        });
    </script>

    <main class="content-section">
        <div class="reveal-container slogan-gap">
            <h2 class="body-slogan">"Inspired by the world we live in.</h2>
        </div>

        <div class="reveal-container">
            <h2 class="body-slogan">Driven by the one we want to see."</h2>
        </div>

        <div class="reveal-container">
            <p class="body-para">
                The world isn't finished yet, and neither are we.
                At <span class="font-baumans"><span class="flip-b">B</span>eBulbed</span>, we believe that the way we live today 
                shouldn't dictate how we live tomorrow.
                Every great idea starts with a single spark — a moment of clarity 
                that illuminates a better path forward.
                Step into a new reality.
                <br /><br />
                <span class="font-baumans"><span class="flip-b">B</span>eInspired.
                <span class="flip-b">B</span>eBulbed.</span>
            </p>
        </div>

        <div class="reveal-container grid-top-margin">
            <div class="t-grid-container">
                <div class="t-row-top">
                    <a href="https://social.bebulbed.com" target="_blank" rel="noopener noreferrer" class="box-card">
                        <h3 class="box-title font-baumans">Social</h3>
                    </a>
                </div>
            </div>
        </div>
    </main>

    <div class="scroll-prompt">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M7 13l5 5 5-5M7 6l5 5 5-5"/>
        </svg>
    </div>
</MainLayout>